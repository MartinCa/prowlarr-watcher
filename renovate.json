{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableRateLimiting",
    ":enableVulnerabilityAlerts"
  ],
  "minimumReleaseAge": "4 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0\\./",
      "automerge": true
    }
  ]
}
